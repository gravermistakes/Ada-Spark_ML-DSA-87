project Deoxysii256 is
   for Source_Dirs use ("src", "tests");
   for Object_Dir use "obj";

   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-O0", "-gnatwa", "-gnata");
   end Compiler;

   package Prove is
      for Proof_Switches ("Ada") use ("--level=2", "--prover=z3,cvc5,altergo");
   end Prove;
end Deoxysii256;
