begin
   for E of Vectors loop
      Got := TBC_Encrypt_384 (E.Key, E.Tweak, E.Plaintext);
      if Got = E.Ciphertext then
         Put_Line ("[PASS] V" & E.Vec_Num'Image & " call" & E.Call_Num'Image
                    & ": " & Hex (E.Ciphertext));
      else
         Put_Line ("[FAIL] V" & E.Vec_Num'Image & " call" & E.Call_Num'Image);
         Put_Line ("       expected = " & Hex (E.Ciphertext));
         Put_Line ("       got      = " & Hex (Got));
         Fails := Fails + 1;
      end if;
   end loop;

   New_Line;
   if Fails = 0 then
      Put_Line ("KAT_TBC GATE PASSED: " & Vectors'Length'Image
                 & " / " & Vectors'Length'Image & " raw TBC calls, "
                 & "source: tests/vectors/peyrin_genkat_deoxysii256.txt "
                 & "(Thomas Peyrin, Deoxys co-designer)");
